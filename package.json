{
  "name": "privatepaste",
  "private": true,
  "workspaces": ["worker", "frontend"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w worker\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "test": "npm test -w worker",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wrangler": "^3.85.0"
  }
}
